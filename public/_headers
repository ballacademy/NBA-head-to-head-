# Always revalidate the HTML shell so deploys cannot leave browsers
# pointing at deleted Vite hashes.
/
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache

# Only long-cache real hashed bundles — not /assets/404.html.
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable

/assets/*.css
  Cache-Control: public, max-age=31536000, immutable

/assets/404.html
  Cache-Control: no-store
