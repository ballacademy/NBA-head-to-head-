# Always revalidate the HTML shell so deploys cannot leave mobile browsers
# pointing at deleted Vite hashes (which previously returned SPA HTML as CSS/JS).
/
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache

# Content-hashed build assets are immutable for the life of the hash.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
