{
  "name": "nba-head-to-head",
  "version": "1.0.0",
  "description": "A head-to-head NBA five-man lineup draft and scoring experience.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "build:impact-rankings": "npx tsx scripts/build_impact_ranking_overrides.ts",
    "data:stats:csv": "python3 scripts/csv_to_stats_json.py --output data/nba-stats/nba-player-stats-202526-regular-season.json",
    "data:salaries:export-pool": "python3 scripts/csv_to_salaries_json.py --export-csv data/manual/nba-salaries.csv --from-json data/nba-salaries-202627.json --stats-pool data/nba-stats/nba-player-stats-202526-regular-season.json",
    "data:salaries:build": "python3 scripts/csv_to_salaries_json.py --input data/manual/nba-salaries.csv --output data/nba-salaries-202627.json --season 2026-27 --stats-pool data/nba-stats/nba-player-stats-202526-regular-season.json --warn-missing-pool",
    "data:manual:test": "python3 scripts/csv_to_stats_json.py --self-test && python3 scripts/csv_to_salaries_json.py --self-test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ballacademy/NBA-head-to-head-.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ballacademy/NBA-head-to-head-/issues"
  },
  "homepage": "https://github.com/ballacademy/NBA-head-to-head-#readme",
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
